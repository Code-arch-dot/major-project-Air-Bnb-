<% layout("/layouts/boilerplate")%>
    <div class="row mt-3">
        <div class="col-8 offset-2" >
    <h3>Edit your listings</h3>
   
    <form method="POST" action="/listings/<%=listing._id%>/?_method=PUT"  novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="md-3">
            <label for="litle" class="form-label">Title</label>
              <input name="listing[title]" value="<%=listing.title%>" type="text" class="form-control" required>
              <div class="valid-feedback">Title good good!</div>
              <div class="invalid-feedback">Please enter valid title!</div>
        </div>

        <div class="md-3">
            <label for="description" class="form-label">Description</label>
             <textarea name="listing[description]" class="form-control" required ><%=listing.description%>   ></textarea>  
             <div class="invalid-feedback">Please enter description!</div>
        </div>
        <br>
         <div class="md-3 card " style="width: 12rem;">
            <img src="<%=originalImageUrl%>" class="card-img-top" />
         </div>
         <br>
           <div class="md-3">
            <label for="image" class="form-label">Upload New Image</label>
             <input name="listing[image]"  type="file" class="form-control" >
            
             
        </div>
       <div class="row">
       <div class="md-3 col-md-4" >
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" value="<%=listing.price%>" type="number" class="form-control" required>
            <div class="invalid-feedback">Please enter valid price!</div>
        </div>

        <div class="md-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" value="<%=listing.country%>" type="string" class="form-control" required>
            <div class="invalid-feedback">country is required!</div>
        </div>
        </div>

          <div class="md-3">
            <label for="location" class="form-label">Location</label>
           <input name="listing[location]"  value="<%=listing.location%>" type="string"  class="form-control" required>
           <div class="invalid-feedback">location is required!</div>
        </div>
       
        <button class="btn btn-dark add-btn mt-3">Edit</button><br><br>
    </form>
     </div>
    </div>
